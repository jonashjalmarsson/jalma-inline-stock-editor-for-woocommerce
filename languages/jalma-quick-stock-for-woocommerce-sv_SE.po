#. translators: %s: plugin name
msgid "%s requires WooCommerce to be active."
msgstr "%s kräver att WooCommerce är aktiverat."

msgid "Quick Stock"
msgstr "Snabbt lager"

msgid "Update stock quantities and low-stock thresholds without opening each product. Inline edit, keyboard navigation, full variation support."
msgstr "Uppdatera lagersaldo och trösklar för lågt lager utan att öppna varje produkt. Inline-redigering, tangentbordsnavigering, fullt stöd för variationer."

msgid "The interactive Quick Stock table will be rendered here. (Scaffold version — table renderer coming in the next iteration.)"
msgstr "Quick Stock-tabellen renderas här. (Scaffold-version — tabellrenderaren kommer i nästa iteration.)"

msgid "Product not found."
msgstr "Produkten hittades inte."

msgid "Product is not a variable product."
msgstr "Produkten är inte en variabel produkt."

msgid "Stock tracking"
msgstr "Lagerspårning"

msgid "Start tracking"
msgstr "Starta spårning"

msgid "Stop tracking"
msgstr "Stoppa spårning"
