# Per-plugin rename rules applied during wp.org build (publish.sh).
#
# wp.org Plugin Review (R jalma-inline-stock-editor/6May26/T2 8May26/3.9)
# flagged the bundled jhlsq-purchase module's "JHLSQ" namespace and
# "jhlsqUpsell" JS global as generic prefixes that aren't unique to this
# plugin. The shared module stays as `jhlsq-*` in the canonical source
# (infra/jhlsq-purchase/) so JCN/RSUC can keep using it; this file rewrites
# every leaked identifier to a plugin-specific prefix when the wp.org zip
# for JISE is built.
#
# Format: <directive>\t<old>\t<new>   (tab-separated)
#   - Lines starting with # are comments.
#   - "path"  → mv of file/folder inside build dir (run first, longest-first).
#   - "sed"   → global s/old/new/g across .php / .js / .css / .txt files.

# ─── Path renames ───────────────────────────────────────────────────────
# Folder + main module file get plugin-prefixed names.
path	jhlsq-purchase/jhlsq-purchase.php	jhlsq-purchase/jise-lsq-purchase.php
path	jhlsq-purchase	jise-lsq-purchase

# ─── Identifier renames (string-level, applied after path mv) ──────────
# Order matters: longer/more-specific patterns first to avoid partial
# matches getting rewritten by earlier rules.
#
# camelCase variants (must come before the lowercase generic `jhlsq` pass).
sed	jhlsqProUpsellCollapsed	jiseLsqProUpsellCollapsed
sed	jhlsqUpsell	jiseLsqUpsell

# Snake_case identifiers (PHP option names, query args, nonces, action defaults).
sed	jhlsq_purchase_install_pro	jise_lsq_install_pro
sed	jhlsq_install_error	jise_lsq_install_error
sed	jhlsq_license_saved	jise_lsq_license_saved
sed	jhlsq_pro_installed	jise_lsq_pro_installed
sed	jhlsq_nonce	jise_lsq_nonce

# Kebab-case identifiers (script handles, HTML IDs, CSS classes).
sed	jhlsq-purchase-upsell	jise-lsq-upsell
sed	jhlsq-license-key-input	jise-lsq-license-key-input
sed	jhlsq-pro-upsell	jise-lsq-pro-upsell
sed	jhlsq-pro-collapse	jise-lsq-pro-collapse
sed	jhlsq-pro-content	jise-lsq-pro-content
sed	jhlsq-pro-status	jise-lsq-pro-status
sed	jhlsq-pro-paste	jise-lsq-pro-paste
sed	jhlsq-pro-saved	jise-lsq-pro-saved
sed	jhlsq-pro-pill	jise-lsq-pro-pill
sed	jhlsq-purchase	jise-lsq-purchase

# PHP namespace + FQCN.
# Two forms exist in source: single-backslash for direct PHP `\JHLSQ\Purchase`
# syntax, double-backslash for string literals like '\\JHLSQ\\Purchase' (used
# with class_exists). Both must be covered.
sed	JHLSQ\\Purchase	JISE_Lsq\\Purchase
sed	JHLSQ\Purchase	JISE_Lsq\Purchase
sed	namespace JHLSQ	namespace JISE_Lsq
